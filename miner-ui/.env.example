# Copy this file to .env and uncomment the line for the network you want to use.

# Local validator (default)
VITE_RPC_URL=http://127.0.0.1:8899

# Devnet (public RPC — fine for low traffic, rate-limited under load)
# VITE_RPC_URL=https://api.devnet.solana.com

# Devnet via a private RPC provider (recommended for any real testing)
# VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
